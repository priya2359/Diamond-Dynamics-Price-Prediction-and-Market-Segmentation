# Copy this file to .env and fill in real values. .env is gitignored.

# Currency conversion (used for display — model trains on USD)
USD_TO_INR=83.5

# MLflow tracking
MLFLOW_TRACKING_URI=sqlite:///artifacts/mlflow/mlflow.db

# FastAPI / serving
API_HOST=0.0.0.0
API_PORT=8000

# Streamlit -> FastAPI (local dev default; docker-compose overrides to
# http://fastapi:8000)
FASTAPI_URL=http://localhost:8000

# Prometheus
PROMETHEUS_PORT=9090

# Grafana (change in production -- default admin/admin is insecure)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Rate limiting (requests per minute per IP)
RATE_LIMIT=60/minute
